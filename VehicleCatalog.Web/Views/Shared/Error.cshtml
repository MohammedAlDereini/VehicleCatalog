@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="search-panel">
    <h1>Something went wrong</h1>
    <p class="lead">An unexpected error occurred while processing your request. Please try again.</p>

    @if (Model.ShowRequestId)
    {
        <p class="hint">Request ID: <code>@Model.RequestId</code></p>
    }

    <p><a class="btn-primary" asp-controller="Home" asp-action="Index">Back to search</a></p>
</section>
